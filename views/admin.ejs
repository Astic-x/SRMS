            </tbody>
          </table>
          <div class="pagination">
            <button class="pag-btn active">1</button>
            <button class="pag-btn">2</button>
            <button class="pag-btn">›</button>
          </div>
        </div>
      </div>

      <!-- ═══ COURSES ═══ -->
      <div id="page-courses" class="page">
        <div class="section-header">
          <h3>Courses</h3>
          <div class="search-wrap">
            <input type="text" class="search-input" placeholder="🔍 Search courses..."
              oninput="filterTable('courses-tbody',this.value)">
            <button class="btn-primary" onclick="openAddModal()">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                <line x1="12" y1="5" x2="12" y2="19" />
                <line x1="5" y1="12" x2="19" y2="12" />
              </svg>
              Add Course
            </button>
          </div>
        </div>
        <div class="table-wrap">
          <table>
            <thead>
              <tr>
                <th>Course Code</th>
                <th>Course Name</th>
                <th>Department</th>
                <th>Credits</th>
                <th>Faculty</th>
                <th>Type</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody id="courses-tbody">
              <tr>
                <td>CS301</td>
                <td><b>Data Structures & Algorithms</b></td>
                <td>CSE</td>
                <td>4</td>
                <td>Dr. Anand Mehta</td>
                <td><span class="tag blue">Core</span></td>
                <td>
                  <div class="action-btns"><button class="btn-edit"
                      onclick="openEditModal('course','CS301')">Edit</button><button class="btn-del"
                      onclick="openDeleteModal('CS301')">Delete</button></div>
                </td>
              </tr>
              <tr>
                <td>CS410</td>
                <td><b>Machine Learning</b></td>
                <td>CSE</td>
