<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>SRMS – Admin Dashboard</title>
  <link
    href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700&family=Syne:wght@700;800&display=swap"
    rel="stylesheet">
  <script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
  <link rel="stylesheet" href="CSS/admin.css?v=3" />
</head>

<body>

  <!-- ─── Sidebar ─── -->
  <aside>
    <div class="logo">
      <h1>SRMS</h1>
      <p>Student Record Management System</p>
    </div>

    <div class="nav-section">
      <div class="nav-label">Main</div>
      <div class="nav-item active" onclick="navigate('dashboard',this)">
        <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <rect x="3" y="3" width="7" height="7" rx="1" />
          <rect x="14" y="3" width="7" height="7" rx="1" />
          <rect x="3" y="14" width="7" height="7" rx="1" />
          <rect x="14" y="14" width="7" height="7" rx="1" />
        </svg>
        Dashboard
      </div>
      <div class="nav-item" onclick="navigate('students',this)">
        <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" />
          <circle cx="9" cy="7" r="4" />
          <path d="M23 21v-2a4 4 0 0 0-3-3.87" />
          <path d="M16 3.13a4 4 0 0 1 0 7.75" />
        </svg>
        Students
      </div>
      <div class="nav-item" onclick="navigate('faculty',this)">
        <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="12" cy="8" r="5" />
          <path d="M20 21a8 8 0 1 0-16 0" />
        </svg>
        Faculty
      </div>
      <div class="nav-item" onclick="navigate('courses',this)">
        <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20" />
          <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z" />
        </svg>
        Courses
      </div>
      <div class="nav-item" onclick="navigate('marks',this)">
        <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
          <polyline points="14 2 14 8 20 8" />
          <line x1="16" y1="13" x2="8" y2="13" />
          <line x1="16" y1="17" x2="8" y2="17" />
          <polyline points="10 9 9 9 8 9" />
        </svg>
        Marks / Grades
      </div>
    </div>

    <div class="nav-section">
      <div class="nav-label">Management</div>
      <div class="nav-item" onclick="navigate('departments',this)">
        <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <rect x="2" y="7" width="20" height="14" rx="2" />
          <path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16" />
        </svg>
        Departments
      </div>
      <div class="nav-item" onclick="navigate('settings',this)">
        <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="12" cy="12" r="3" />
          <path d="M19.07 4.93a10 10 0 0 1 0 14.14M4.93 4.93a10 10 0 0 0 0 14.14" />
        </svg>
        Settings
      </div>
    </div>

    <div class="sidebar-footer">
      <div class="avatar">AD</div>
      <div class="avatar-info">
        <div class="name">Admin</div>
        <div class="role">Super Administrator</div>
      </div>
    </div>
  </aside>

  <!-- ─── Main ─── -->
  <main>
    <div class="topbar">
      <h2 id="page-title">Dashboard</h2>
      <div class="topbar-actions">
        <button class="btn-icon"><svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor"
            stroke-width="2">
            <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9" />
            <path d="M13.73 21a2 2 0 0 1-3.46 0" />
          </svg><span class="badge"></span></button>
        <button id="main-add-btn" class="btn-primary" onclick="openAddModal()">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
            <line x1="12" y1="5" x2="12" y2="19" />
            <line x1="5" y1="12" x2="19" y2="12" />
          </svg>
          Add Student
        </button>
      </div>
    </div>

    <div class="content">

      <!-- ═══ DASHBOARD ═══ -->
      <div id="page-dashboard" class="page active">
        <div class="stats-grid">
          <div class="stat-card">
            <div class="stat-icon blue"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#2563eb"
                stroke-width="2">
                <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" />
                <circle cx="9" cy="7" r="4" />
                <path d="M23 21v-2a4 4 0 0 0-3-3.87" />
                <path d="M16 3.13a4 4 0 0 1 0 7.75" />
              </svg></div>
            <div class="stat-body">
              <div class="label">Total Students</div>
              <div class="value">1,248</div>
              <div class="change up">↑ 24 this semester</div>
            </div>
          </div>
          <div class="stat-card">
            <div class="stat-icon green"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#16a34a"
                stroke-width="2">
                <circle cx="12" cy="8" r="5" />
                <path d="M20 21a8 8 0 1 0-16 0" />
              </svg></div>
            <div class="stat-body">
              <div class="label">Faculty Members</div>
              <div class="value">84</div>
              <div class="change up">↑ 3 new this month</div>
            </div>
          </div>
          <div class="stat-card">
            <div class="stat-icon orange"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#ea580c"
                stroke-width="2">
                <rect x="2" y="7" width="20" height="14" rx="2" />
                <path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16" />
              </svg></div>
            <div class="stat-body">
              <div class="label">Departments</div>
              <div class="value">6</div>
              <div class="change neutral">No change</div>
            </div>
          </div>
          <div class="stat-card">
            <div class="stat-icon red"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#dc2626"
                stroke-width="2">
                <polyline points="22 12 18 12 15 21 9 3 6 12 2 12" />
              </svg></div>
            <div class="stat-body">
              <div class="label">Avg. Attendance</div>
              <div class="value">87%</div>
              <div class="change down">↓ 2% vs last week</div>
            </div>
          </div>
        </div>

        <div class="charts-row">
          <div class="chart-card">
            <div class="chart-header">
              <span class="chart-title">Enrollment by Branch</span>
              <select class="select-sm">
                <option>2024–25</option>
                <option>2023–24</option>
                <option>2022–23</option>
              </select>
            </div>
            <div class="chart-wrap"><canvas id="enrollChart"></canvas></div>
            <div style="display:flex;gap:16px;margin-top:14px;font-size:12px;font-weight:600;">
              <span style="display:flex;align-items:center;gap:5px;"><span
                  style="width:10px;height:10px;border-radius:3px;background:#2563eb;display:inline-block;"></span>Active</span>
              <span style="display:flex;align-items:center;gap:5px;"><span
                  style="width:10px;height:10px;border-radius:3px;background:#cbd5e1;display:inline-block;"></span>Inactive</span>
            </div>
          </div>
          <div class="chart-card">
            <div class="chart-header"><span class="chart-title">Branch Breakdown</span></div>
            <div class="activity-list" style="margin-top:4px;">
              <div class="branch-row"><span class="branch-name">CSE</span>
                <div class="bar-track">
                  <div class="bar-fill" style="width:78%;background:#2563eb"></div>
                </div><span class="branch-count">380</span>
              </div>
              <div class="branch-row"><span class="branch-name">ECE</span>
                <div class="bar-track">
                  <div class="bar-fill" style="width:54%;background:#7c3aed"></div>
                </div><span class="branch-count">218</span>
              </div>
              <div class="branch-row"><span class="branch-name">ME</span>
                <div class="bar-track">
                  <div class="bar-fill" style="width:47%;background:#0891b2"></div>
                </div><span class="branch-count">195</span>
              </div>
              <div class="branch-row"><span class="branch-name">Civil</span>
                <div class="bar-track">
                  <div class="bar-fill" style="width:42%;background:#16a34a"></div>
                </div><span class="branch-count">175</span>
              </div>
              <div class="branch-row"><span class="branch-name">IT</span>
                <div class="bar-track">
                  <div class="bar-fill" style="width:38%;background:#ea580c"></div>
                </div><span class="branch-count">160</span>
              </div>
              <div class="branch-row"><span class="branch-name">BT</span>
                <div class="bar-track">
                  <div class="bar-fill" style="width:26%;background:#db2777"></div>
                </div><span class="branch-count">120</span>
              </div>
            </div>
          </div>
        </div>

        <div class="chart-card">
          <div class="chart-header"><span class="chart-title">Recent Activity</span></div>
          <div class="activity-list">
            <div class="activity-item">
              <div class="activity-dot" style="background:#16a34a"></div>
              <div>
                <div class="activity-text">New student <b>Riya Sharma</b> registered in CSE department.</div>
                <div class="activity-time">2 minutes ago</div>
              </div>
            </div>
            <div class="activity-item">
              <div class="activity-dot" style="background:#2563eb"></div>
              <div>
                <div class="activity-text">Faculty <b>Dr. Anand Mehta</b> updated marks for CS301.</div>
                <div class="activity-time">18 minutes ago</div>
              </div>
            </div>
            <div class="activity-item">
              <div class="activity-dot" style="background:#ea580c"></div>
              <div>
                <div class="activity-text">Department <b>IT</b> course list was updated by Admin.</div>
                <div class="activity-time">1 hour ago</div>
              </div>
            </div>
            <div class="activity-item">
              <div class="activity-dot" style="background:#dc2626"></div>
              <div>
                <div class="activity-text">Student <b>Arjun Rawat</b> was marked inactive.</div>
                <div class="activity-time">3 hours ago</div>
              </div>
            </div>
            <div class="activity-item">
              <div class="activity-dot" style="background:#7c3aed"></div>
              <div>
                <div class="activity-text">New course <b>Machine Learning (CS410)</b> added to CSE department.</div>
                <div class="activity-time">Yesterday</div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- ═══ STUDENTS ═══ -->
      <div id="page-students" class="page">
        <div class="section-header">
          <h3>Students</h3>
          
          <div class="search-wrap">
            <select class="search-col-filter" style="padding:4px;border:1px solid #cbd5e1;border-radius:4px;" onchange="filterTable('students-tbody', this.nextElementSibling.value, this.value)">
              <option value="all">All Columns</option>
              <option value="0">Student ID</option>
              <option value="1">Name</option>
              <option value="2">Department</option>
              <option value="3">Semester</option>
              <option value="4">Attendance</option>
              <option value="5">Status</option>
            </select>
            <input type="text" class="search-input" placeholder="🔍 Search students..."
              oninput="filterTable('students-tbody', this.value, this.previousElementSibling.value)">

            <button class="btn-primary" onclick="openAddModal()">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                <line x1="12" y1="5" x2="12" y2="19" />
                <line x1="5" y1="12" x2="19" y2="12" />
              </svg>
              Add Student
            </button>
          </div>
        </div>
        <div class="table-wrap">
          <table>
            <thead>
              <tr>
                <th>Student ID</th>
                <th>Name</th>
                <th>Department</th>
                <th>Semester</th>
                <th>Attendance</th>
                <th>Status</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody id="students-tbody">

              <% if (typeof students !== 'undefined' && students.length > 0) { %>
                <% students.forEach(student => { %>
                  <tr>
                    <td><%= student.student_id %></td>
                    <td><b><%= student.name %></b></td>
                    <td><%= student.dept_name %></td>
                    <td><%= student.current_semester %></td>
                    <td><%= student.attendance_percent ?? 0 %>%</td>
                    <td><span class="tag active">Active</span></td>
                    <td>
                      <div class="action-btns">
                        <button class="btn-edit" onclick='openEditModal(<%- JSON.stringify(student) %>)'>Edit</button>
                        <button class="btn-del" onclick="openDeleteModal(<%= student.student_id %>)">Delete</button>
                      </div>
                    </td>
                  </tr>
                <% }) %>
              <% } else { %>
                <tr><td colspan="7" style="text-align:center;">No students found</td></tr>
              <% } %>

            </tbody>
          </table>
          <div class="pagination">
            <button class="pag-btn active">1</button>
            <button class="pag-btn">2</button>
            <button class="pag-btn">3</button>
            <button class="pag-btn">›</button>
          </div>
        </div>
      </div>

      <!-- ═══ FACULTY ═══ -->
      <div id="page-faculty" class="page">
        <div class="section-header">
          <h3>Faculty</h3>
          
          <div class="search-wrap">
            <select class="search-col-filter" style="padding:4px;border:1px solid #cbd5e1;border-radius:4px;" onchange="filterTable('faculty-tbody', this.nextElementSibling.value, this.value)">
              <option value="all">All Columns</option>
              <option value="0">Faculty ID</option>
              <option value="1">Name</option>
              <option value="2">Department</option>
              <option value="3">Designation</option>
              <option value="4">Status</option>
            </select>
            <input type="text" class="search-input" placeholder="🔍 Search faculty..."
              oninput="filterTable('faculty-tbody', this.value, this.previousElementSibling.value)">

            <button class="btn-primary" onclick="openAddFacultyModal()">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                <line x1="12" y1="5" x2="12" y2="19" />
                <line x1="5" y1="12" x2="19" y2="12" />
              </svg>
              Add Faculty
            </button>
          </div>
        </div>
        <div class="table-wrap">
          <table>
            <thead>
              <tr>
                <th>Faculty ID</th>
                <th>Name</th>
                <th>Department</th>
                <th>Designation</th>
                <th>Status</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody id="faculty-tbody">

              <% if (typeof faculty !== 'undefined' && faculty.length > 0) { %>
                <% faculty.forEach(fac => { %>
                  <tr>
                    <td><%= fac.faculty_id %></td>
                    <td><b><%= fac.name %></b></td>
                    <td><%= fac.dept_name %></td>
                    <td><%= fac.designation %></td>
                    <td><span class="tag active">Active</span></td>
                    <td>
                      <div class="action-btns">
                        <button class="btn-edit" onclick='openEditFacultyModal(<%- JSON.stringify(fac) %>)'>Edit</button>
                        <button class="btn-del" onclick="openDeleteFacultyModal(<%= fac.faculty_id %>)">Delete</button>
                      </div>
                    </td>
                  </tr>
                <% }) %>
              <% } else { %>
                <tr><td colspan="6" style="text-align:center;">No faculty members found</td></tr>
              <% } %>

            </tbody>
          </table>
        </div>
      </div>

      <!-- ═══ COURSES ═══ -->
      <div id="page-courses" class="page">
        <div class="section-header">
          <h3>Courses</h3>
          
          <div class="search-wrap">
            <select class="search-col-filter" style="padding:4px;border:1px solid #cbd5e1;border-radius:4px;" onchange="filterTable('courses-tbody', this.nextElementSibling.value, this.value)">
              <option value="all">All Columns</option>
              <option value="0">Course Code</option>
              <option value="1">Course Name</option>
              <option value="2">Department</option>
              <option value="3">Credits</option>
              <option value="4">Faculty</option>
            </select>
            <input type="text" class="search-input" placeholder="🔍 Search courses..."
              oninput="filterTable('courses-tbody', this.value, this.previousElementSibling.value)">

            <button class="btn-primary" onclick="openAddCourseModal()">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                <line x1="12" y1="5" x2="12" y2="19" />
                <line x1="5" y1="12" x2="19" y2="12" />
              </svg>
              Add Course
            </button>
          </div>
        </div>
        <div class="table-wrap">
          <table>
            <thead>
              <tr>
                <th>Course Code</th>
                <th>Course Name</th>
                <th>Department</th>
                <th>Credits</th>
                <th>Faculty</th>
                <th>Type</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody id="courses-tbody">

              <% if (typeof courses !== 'undefined' && courses.length > 0) { %>
                <% courses.forEach(course => { %>
                  <tr>
                    <td><%= course.course_code %></td>
                    <td><b><%= course.course_name %></b></td>
                    <td><%= course.dept_name %></td>
                    <td><%= course.credits %></td>
                    <td><%= course.faculty_name || 'Unassigned' %></td>
                    <td><span class="tag blue">Core</span></td>
                    <td>
                      <div class="action-btns">
                        <button class="btn-edit" onclick='openEditCourseModal(<%- JSON.stringify(course) %>)'>Edit</button>
                        <button class="btn-del" onclick="openDeleteCourseModal('<%= course.course_code %>')">Delete</button>
                      </div>
                    </td>
                  </tr>
                <% }) %>
              <% } else { %>
                <tr><td colspan="7" style="text-align:center;">No courses found</td></tr>
              <% } %>

            </tbody>
          </table>
          <div class="pagination">
            <button class="pag-btn active">1</button>
            <button class="pag-btn">2</button>
            <button class="pag-btn">›</button>
          </div>
        </div>
      </div>

      <!-- ═══ MARKS ═══ -->
      <div id="page-marks" class="page">
        <div class="section-header">
          <h3>Marks / Grades</h3>
          
          <div class="search-wrap">
            <select class="search-col-filter" style="padding:4px;border:1px solid #cbd5e1;border-radius:4px;" onchange="filterTable('marks-tbody', this.nextElementSibling.value, this.value)">
              <option value="all">All Columns</option>
              <option value="0">Roll No.</option>
              <option value="1">Student Name</option>
              <option value="2">Course Code</option>
              <option value="6">Calculated Grade</option>
            </select>
            <input type="text" class="search-input" placeholder="🔍 Search records..."
              oninput="filterTable('marks-tbody', this.value, this.previousElementSibling.value)">

            <select class="select-sm" onchange="filterMarksBySemester(this.value)">
              <option value="all">All Semesters</option>
              <option value="1">1st</option>
              <option value="2">2nd</option>
              <option value="3">3rd</option>
              <option value="4">4th</option>
              <option value="5">5th</option>
              <option value="6">6th</option>
              <option value="7">7th</option>
              <option value="8">8th</option>
            </select>
            <button class="btn-primary" onclick="openAddMarksModal()">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                <line x1="12" y1="5" x2="12" y2="19" />
                <line x1="5" y1="12" x2="19" y2="12" />
              </svg>
              Add Marks
            </button>
          </div>
        </div>
        <div class="table-wrap">
          <table>
            <thead>
              <tr>
                <th>Roll No.</th>
                <th>Student Name</th>
                <th>Course</th>
                <th>Internal</th>
                <th>External</th>
                <th>Total</th>
                <th>Grade</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody id="marks-tbody">

              <% if (typeof marks !== 'undefined' && marks.length > 0) { %>
                <% marks.forEach(mark => { 
                    const gradeClass = mark.grade === 'A+' || mark.grade === 'A' ? 'green' :
                                     mark.grade === 'B+' || mark.grade === 'B' ? 'blue' :
                                     mark.grade === 'C' ? 'orange' : 'red';
                %>
                  <tr>
                    <td><%= mark.student_id %></td>
                    <td><b><%= mark.student_name %></b></td>
                    <td><%= mark.course_code %></td>
                    <td><%= mark.internal_marks %>/40</td>
                    <td><%= mark.external_marks %>/60</td>
                    <td><%= mark.total_marks %>/100</td>
                    <td><span class="tag <%= gradeClass %>"><%= mark.grade %></span></td>
                    <td class="mark-sem" style="display:none;"><%= mark.current_semester %></td>
                    <td>
                      <div class="action-btns">
                        <button class="btn-edit" onclick='openEditMarksModal(<%- JSON.stringify(mark) %>)'>Edit</button>
                        <button class="btn-del" onclick="openDeleteMarksModal(<%= mark.enrollment_id %>)">Delete</button>
                      </div>
                    </td>
                  </tr>
                <% }) %>
              <% } else { %>
                <tr><td colspan="8" style="text-align:center;">No records found</td></tr>
              <% } %>

            </tbody>
          </table>
        </div>
      </div>

      <!-- ═══ DEPARTMENTS ═══ -->
      <div id="page-departments" class="page">
        <div class="section-header">
          <h3>Departments</h3>
          
          <div class="search-wrap">
            <select class="search-col-filter" style="padding:4px;border:1px solid #cbd5e1;border-radius:4px;" onchange="filterTable('dept-tbody', this.nextElementSibling.value, this.value)">
              <option value="all">All Columns</option>
              <option value="0">Code</option>
              <option value="1">Department Name</option>
              <option value="2">Location</option>
            </select>
            <input type="text" class="search-input" placeholder="🔍 Search departments..."
              oninput="filterTable('dept-tbody', this.value, this.previousElementSibling.value)">

            <button class="btn-primary" onclick="openAddDeptModal()">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                <line x1="12" y1="5" x2="12" y2="19" />
                <line x1="5" y1="12" x2="19" y2="12" />
              </svg>
              Add Department
            </button>
          </div>
        </div>
        <div class="table-wrap">
          <table>
            <thead>
              <tr>
                <th>Code</th>
                <th>Department Name</th>
                <th>HOD</th>
                <th>Students</th>
                <th>Courses</th>
                <th>Status</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody id="dept-tbody">

              <% if (typeof departments !== 'undefined' && departments.length > 0) { %>
                <% departments.forEach(dept => { %>
                  <tr>
                    <td><%= dept.dept_id %></td>
                    <td><b><%= dept.dept_name %></b></td>
                    <td><%= dept.building_location || 'N/A' %></td>
                    <td><%= dept.student_count %></td>
                    <td><%= dept.course_count %></td>
                    <td><span class="tag active">Active</span></td>
                    <td>
                      <div class="action-btns">
                        <button class="btn-edit" onclick='openEditDeptModal(<%- JSON.stringify(dept) %>)'>Edit</button>
                        <button class="btn-del" onclick="openDeleteDeptModal(<%= dept.dept_id %>)">Delete</button>
                      </div>
                    </td>
                  </tr>
                <% }) %>
              <% } else { %>
                <tr><td colspan="7" style="text-align:center;">No departments found</td></tr>
              <% } %>

            </tbody>
          </table>
        </div>
      </div>

      <!-- ═══ SETTINGS ═══ -->
      
      <div id="page-settings" class="page">
        <div class="section-header">
          <h3>Settings</h3>
        </div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;">
          <div class="chart-card">
            <div class="chart-title" style="margin-bottom:18px;">Profile Settings</div>
            <form id="profile-form" onsubmit="event.preventDefault(); handleSaveProfile()">
              <div class="form-group"><label>Username (Login ID)</label><input type="text" id="set_username" required value="<%= typeof admin_user !== 'undefined' ? admin_user.login_id : 'admin' %>"></div>
              <div class="form-group"><label>Role</label><input type="text" value="Super Administrator" disabled style="background:#f1f5f9;color:#64748b"></div>
              <p style="font-size:12px; color:#64748b; margin-top:10px;">Note: Profile properties are strictly synced with the Users database table.</p>
              <button class="btn-primary" style="margin-top:10px;" type="submit">Save Changes</button>
            </form>
          </div>
          
          <div class="chart-card">
            <div class="chart-title" style="margin-bottom:18px;">Change Password</div>
            <form id="password-form" onsubmit="event.preventDefault(); handleSavePassword()">
              <div class="form-group"><label>Current Password</label><input type="password" id="set_pw_current" placeholder="••••••••" required></div>
              <div class="form-group"><label>New Password</label><input type="password" id="set_pw_new" placeholder="••••••••" required></div>
              <div class="form-group"><label>Confirm New Password</label><input type="password" id="set_pw_confirm" placeholder="••••••••" required></div>
              <button class="btn-primary" style="margin-top:4px;" type="submit">Update Password</button>
            </form>
          </div>

          <div class="chart-card" style="grid-column:span 2">
            <div class="chart-title" style="margin-bottom:18px;">System Preferences</div>
            <form id="preferences-form" onsubmit="event.preventDefault(); handleSavePreferences()">
              <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:16px;">
                <div class="form-group"><label>Academic Year</label>
                  <select id="pref_year" class="select-sm" style="width:100%">
                    <option>2024–25</option>
                    <option>2023–24</option>
                  </select>
                </div>
                <div class="form-group"><label>Default Semester</label>
                  <select id="pref_sem" class="select-sm" style="width:100%">
                    <option>1st</option><option>2nd</option><option>3rd</option><option>4th</option><option>5th</option><option>6th</option><option>7th</option><option>8th</option>
                  </select>
                </div>
                <div class="form-group"><label>Timezone</label>
                  <select id="pref_tz" class="select-sm" style="width:100%">
                    <option>IST (UTC+5:30)</option>
                    <option>UTC</option>
                  </select>
                </div>
              </div>
              <button class="btn-primary" style="margin-top:4px;" type="submit">Save Preferences</button>
            </form>
          </div>
        </div>
      </div>
    </div><!-- /content -->
  </main>

  
  <!-- ─── Student Modal ─── -->
  <div class="overlay" id="student-modal" onclick="closeModal(event)">
    <div class="modal">
      <div class="modal-header">
        <h3 id="student-modal-title">Add Student</h3>
        <button type="button" class="modal-close" onclick="closeAllModals()">✕</button>
      </div>
      <form id="student-form" onsubmit="event.preventDefault(); handleSaveStudent()">
        <div class="modal-body" id="modal-body" style="padding:20px; max-height:400px; overflow-y:auto;">
            <input type="hidden" id="student_id_field" value="">
            
            <div class="form-group">
            <label>First Name</label>
            <input type="text" id="stu_first_name" required maxlength="50" pattern="[A-Za-z ]+">
            </div>

            <div class="form-group">
            <label>Last Name</label>
            <input type="text" id="stu_last_name" required maxlength="50" pattern="[A-Za-z ]+">
            </div>

            <div class="form-group">
            <label>Email</label>
            <input type="email" id="stu_email" required maxlength="100">
            </div>

            <div class="form-group">
            <label>Phone Number</label>
            <input type="tel" id="stu_phone" required pattern="[\\+]?[0-9]{10,14}" maxlength="15">
            </div>

            <div class="form-group">
            <label>Date of Birth</label>
            <input type="date" id="stu_dob" required max="<%= new Date().toISOString().split('T')[0] %>">
            </div>

            <div class="form-group">
            <label>Department</label>
            <select id="stu_dept" required>
                <option value="">-- Select --</option>
                
              <% if (typeof departments !== 'undefined') { %>
                <% departments.forEach(d => { %>
                  <option value="<%= d.dept_id %>"><%= d.dept_name %></option>
                <% }) %>
              <% } %>

            </select>
            </div>

            <div class="form-group">
            <label>Semester</label>
            <input type="number" id="stu_semester" required min="1" max="8" value="1">
            <script>
                // Defaults to pref_sem if set
                const pSem = localStorage.getItem('pref_sem');
                if(pSem) {
                    const mapped = parseInt(pSem);
                    if(!isNaN(mapped)) document.getElementById('stu_semester').value = mapped;
                }
            </script>
            </div>
        </div>
        <div class="modal-footer" style="padding:15px 20px; text-align:right;">
            <button type="button" class="btn-cancel" onclick="closeAllModals()">Cancel</button>
            <button type="submit" class="btn-save">Save</button>
        </div>
      </form>
    </div>
  </div>

  <!-- ─── Faculty Modal ─── -->
  <div class="overlay" id="faculty-modal" onclick="closeModal(event)">
    <div class="modal">
      <div class="modal-header">
        <h3 id="faculty-modal-title">Add Faculty</h3>
        <button type="button" class="modal-close" onclick="closeAllModals()">✕</button>
      </div>
      <form id="faculty-form" onsubmit="event.preventDefault(); handleSaveFaculty()">
        <div class="modal-body" style="padding:20px; max-height:400px; overflow-y:auto;">
            <input type="hidden" id="faculty_id_field" value="">
            
            <div class="form-group">
            <label>Name</label>
            <input type="text" id="fac_name" required maxlength="100">
            </div>

            <div class="form-group">
            <label>Email</label>
            <input type="email" id="fac_email" required maxlength="100">
            </div>

            <div class="form-group">
            <label>Phone Number</label>
            <input type="tel" id="fac_phone" required pattern="[\\+]?[0-9]{10,14}" maxlength="15">
            </div>

            <div class="form-group">
            <label>Designation</label>
            <input type="text" id="fac_designation" required maxlength="50">
            </div>

            <div class="form-group">
            <label>Department</label>
            <select id="fac_dept" required>
                <option value="">-- Select --</option>
                
              <% if (typeof departments !== 'undefined') { %>
                <% departments.forEach(d => { %>
                  <option value="<%= d.dept_id %>"><%= d.dept_name %></option>
                <% }) %>
              <% } %>

            </select>
            </div>
        </div>
        <div class="modal-footer" style="padding:15px 20px; text-align:right;">
            <button type="button" class="btn-cancel" onclick="closeAllModals()">Cancel</button>
            <button type="submit" class="btn-save">Save</button>
        </div>
      </form>
    </div>
  </div>

  <!-- ─── Course Modal ─── -->
  <div class="overlay" id="course-modal" onclick="closeModal(event)">
    <div class="modal">
      <div class="modal-header">
        <h3 id="course-modal-title">Add Course</h3>
        <button type="button" class="modal-close" onclick="closeAllModals()">✕</button>
      </div>
      <form id="course-form" onsubmit="event.preventDefault(); handleSaveCourse()">
        <div class="modal-body" style="padding:20px; max-height:400px; overflow-y:auto;">
            <input type="hidden" id="course_is_edit" value="false">
            <div class="form-group">
            <label>Course Code</label>
            <input type="text" id="crs_code" required maxlength="10" pattern="[A-Z0-9]+">
            </div>

            <div class="form-group">
            <label>Course Name</label>
            <input type="text" id="crs_name" required maxlength="100">
            </div>

            <div class="form-group">
            <label>Credits</label>
            <input type="number" id="crs_credits" required min="1" max="10">
            </div>

            <div class="form-group">
            <label>Department</label>
            <select id="crs_dept" required onchange="filterFacultyDropdown()">
                <option value="">-- Select --</option>
                
              <% if (typeof departments !== 'undefined') { %>
                <% departments.forEach(d => { %>
                  <option value="<%= d.dept_id %>"><%= d.dept_name %></option>
                <% }) %>
              <% } %>

            </select>
            </div>

            <div class="form-group">
            <label>Faculty (Optional)</label>
            <select id="crs_faculty">
                <option value="">-- Select Faculty --</option>
                
              <% if (typeof faculty !== 'undefined') { %>
                <% faculty.forEach(f => { %>
                  <option value="<%= f.faculty_id %>" data-dept="<%= f.dept_id %>"><%= f.name %></option>
                <% }) %>
              <% } %>

            </select>
            </div>
        </div>
        <div class="modal-footer" style="padding:15px 20px; text-align:right;">
            <button type="button" class="btn-cancel" onclick="closeAllModals()">Cancel</button>
            <button type="submit" class="btn-save">Save</button>
        </div>
      </form>
    </div>
  </div>

  <!-- ─── Marks Modal ─── -->
  <div class="overlay" id="marks-modal" onclick="closeModal(event)">
    <div class="modal">
      <div class="modal-header">
        <h3 id="marks-modal-title">Add Marks</h3>
        <button type="button" class="modal-close" onclick="closeAllModals()">✕</button>
      </div>
      <form id="marks-form" onsubmit="event.preventDefault(); handleSaveMarks()">
        <div class="modal-body" style="padding:20px; max-height:400px; overflow-y:auto;">
            <input type="hidden" id="mrk_id_field" value="">
            
            
            <div class="form-group" id="mrk_student_sg">
            <label>Student</label>
            <select id="mrk_student_id" required>
                <option value="">-- Select Student --</option>
                <% if (typeof students !== 'undefined') { %>
                  <% students.forEach(s => { %>
                    <option value="<%= s.student_id %>"><%= s.name %> (ID: <%= s.student_id %>)</option>
                  <% }) %>
                <% } %>
            </select>
            </div>

            <div class="form-group" id="mrk_course_sg">
            <label>Course</label>
            <select id="mrk_course_code" required>
                <option value="">-- Select Course --</option>
                <% if (typeof courses !== 'undefined') { %>
                  <% courses.forEach(c => { %>
                    <option value="<%= c.course_code %>"><%= c.course_name %> (<%= c.course_code %>)</option>
                  <% }) %>
                <% } %>
            </select>
            </div>


            <div class="form-group">
            <label>Internal Marks (Out of 40)</label>
            <input type="number" id="mrk_internal" required min="0" max="40" step="0.01" oninput="updateCalculatedGrade()">
            </div>

            <div class="form-group">
            <label>External Marks (Out of 60)</label>
            <input type="number" id="mrk_external" required min="0" max="60" step="0.01" oninput="updateCalculatedGrade()">
            </div>

            <div class="form-group">
            <label>Calculated Grade</label>
            <input type="text" id="mrk_grade" readonly placeholder="Auto-calculated" style="background:#f1f5f9;">
            </div>
        </div>
        <div class="modal-footer" style="padding:15px 20px; text-align:right;">
            <button type="button" class="btn-cancel" onclick="closeAllModals()">Cancel</button>
            <button type="submit" class="btn-save">Save</button>
        </div>
      </form>
    </div>
  </div>

  <!-- ─── Department Modal ─── -->
  <div class="overlay" id="dept-modal" onclick="closeModal(event)">
    <div class="modal">
      <div class="modal-header">
        <h3 id="dept-modal-title">Add Department</h3>
        <button type="button" class="modal-close" onclick="closeAllModals()">✕</button>
      </div>
      <form id="dept-form" onsubmit="event.preventDefault(); handleSaveDept()">
        <div class="modal-body" style="padding:20px; max-height:400px; overflow-y:auto;">
            <input type="hidden" id="dpt_id_field" value="">
            
            <div class="form-group">
            <label>Department Name</label>
            <input type="text" id="dpt_name" required maxlength="100">
            </div>

            <div class="form-group">
            <label>Building / Location</label>
            <input type="text" id="dpt_loc" maxlength="100">
            </div>
        </div>
        <div class="modal-footer" style="padding:15px 20px; text-align:right;">
            <button type="button" class="btn-cancel" onclick="closeAllModals()">Cancel</button>
            <button type="submit" class="btn-save">Save</button>
        </div>
      </form>
    </div>
  </div>

  </div>

  <!-- ─── Delete Confirm Modal ─── -->
  <div class="overlay" id="delete-overlay" onclick="closeModal(event)">
    <div class="modal confirm-modal">
      <div class="confirm-icon">⚠️</div>
      <h3>Confirm Delete</h3>
      <p id="delete-msg">Are you sure you want to delete <b>Aarav Sharma</b>? This action cannot be undone.</p>
      <div style="display:flex;justify-content:center;gap:10px;">
        <button class="btn-cancel" onclick="closeAllModals()">Cancel</button>
        <button class="btn-del-confirm" onclick="handleDelete()">Yes, Delete</button>
      </div>
    </div>
  </div>

  <!-- ─── Toast ─── -->
  <div class="toast" id="toast"></div>

  <script src="JS/admin.js"></script>
</body>

</html>