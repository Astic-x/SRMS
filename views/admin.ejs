                <td>
                  <div class="action-btns"><button class="btn-edit"
                      onclick="openEditModal('faculty','Dr. Anand Mehta')">Edit</button><button class="btn-del"
                      onclick="openDeleteModal('Dr. Anand Mehta')">Delete</button></div>
                </td>
              </tr>
              <tr>
                <td>FAC002</td>
