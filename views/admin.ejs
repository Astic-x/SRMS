                      onclick="openDeleteModal('Dr. Rajesh Pant')">Delete</button></div>
                </td>
              </tr>
              <tr>
                <td>FAC004</td>
                <td><b>Ms. Pooja Arora</b></td>
                <td>IT</td>
                <td>Lecturer</td>
                <td>IT301</td>
                <td><span class="tag inactive">Inactive</span></td>
                <td>
                  <div class="action-btns"><button class="btn-edit"
                      onclick="openEditModal('faculty','Ms. Pooja Arora')">Edit</button><button class="btn-del"
                      onclick="openDeleteModal('Ms. Pooja Arora')">Delete</button></div>
                </td>
              </tr>
              <tr>
                <td>FAC005</td>
                <td><b>Dr. Manoj Kumar</b></td>
                <td>Civil</td>
                <td>Professor</td>
                <td>CE401, CE210</td>
                <td><span class="tag active">Active</span></td>
                <td>
                  <div class="action-btns"><button class="btn-edit"
                      onclick="openEditModal('faculty','Dr. Manoj Kumar')">Edit</button><button class="btn-del"
                      onclick="openDeleteModal('Dr. Manoj Kumar')">Delete</button></div>
                </td>
              </tr>
              <tr>
                <td>FAC006</td>
                <td><b>Dr. Neha Singh</b></td>
                <td>BT</td>
