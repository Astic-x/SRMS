courses.forEach(c => {
  cgEl.innerHTML += `
    <div class="course-card" onclick="selectCourse('${c.code}')">
      <div class="course-top">
        <div>
          <div class="course-code">${c.code}</div>
          <div class="course-name">${c.name}</div>
        </div>
        <span class="badge ${c.submitted ? 'active' : 'pending'}">${c.submitted ? 'Marks Done' : 'Pending'}</span>
      </div>
      <div style="font-size:12px;color:var(--text-muted)">Semester: ${c.sem}</div>
      <div class="course-meta">
        <div class="course-meta-item"><div class="course-meta-val" style="color:${c.accent}">${c.students}</div><div class="course-meta-lbl">Students</div></div>
        <div class="course-meta-item"><div class="course-meta-val" style="color:${c.accent}">82%</div><div class="course-meta-lbl">Avg Att.</div></div>
        <div class="course-meta-item"><div class="course-meta-val" style="color:${c.accent}">24</div><div class="course-meta-lbl">Classes</div></div>
      </div>
    </div>
  `;
});
function selectCourse(code) {
  document.querySelectorAll('.course-card').forEach(c => c.classList.remove('selected'));
  event.currentTarget.classList.add('selected');
}

// ── ATTENDANCE TABLE ──
function renderAttTable(course) {
  const list = attendanceStudents[course] || [];
  const tbody = document.getElementById('attTbody');
  tbody.innerHTML = list.map(s => {
    const key = course + '_' + s.roll;
    const cur = attState[key] || 'present';
    return `
      <tr>
        <td style="font-family:'DM Mono',monospace;font-size:12px;color:var(--text-muted)">${s.roll}</td>
        <td><strong>${s.name}</strong></td>
        <td>
          <div style="display:flex;gap:6px">
            <button onclick="setAtt('${key}','present',this)" class="att-pill p ${cur==='present'?'':'opacity-low'}" style="cursor:pointer;border:none;opacity:${cur==='present'?1:0.4}">P</button>
            <button onclick="setAtt('${key}','absent',this)"  class="att-pill a ${cur==='absent'?'':'opacity-low'}"  style="cursor:pointer;border:none;opacity:${cur==='absent'?1:0.4}">A</button>
            <button onclick="setAtt('${key}','late',this)"    class="att-pill l ${cur==='late'?'':'opacity-low'}"    style="cursor:pointer;border:none;opacity:${cur==='late'?1:0.4}">L</button>
          </div>
        </td>
        <td><input type="text" placeholder="Optional remark" style="border:1px solid var(--border);border-radius:6px;padding:5px 10px;font-size:12px;font-family:'DM Sans',sans-serif;width:180px;background:#fff"></td>
      </tr>
    `;
  });
  updateAttCounts();
}
function setAtt(key, val, btn) {
  attState[key] = val;
  const row = btn.closest('tr');
  row.querySelectorAll('.att-pill').forEach(b => b.style.opacity = '0.4');
  btn.style.opacity = '1';
  updateAttCounts();
}
function updateAttCounts() {
  const vals = Object.values(attState);
  document.getElementById('pCount').textContent = 'P: ' + vals.filter(v=>v==='present').length;
  document.getElementById('aCount').textContent = 'A: ' + vals.filter(v=>v==='absent').length;
  document.getElementById('lCount').textContent = 'L: ' + vals.filter(v=>v==='late').length;
}
function selectAllAtt(val, el) {
  document.querySelectorAll('.att-toggle-btn').forEach(b => b.classList.remove('sel'));
  el.classList.add('sel');
  const course = document.querySelector('#page-attendance select').value;
  const list = attendanceStudents[course] || [];
  list.forEach(s => { attState[course+'_'+s.roll] = val; });
  renderAttTable(course);
}
function saveAttendance() { showToast('✅ Attendance saved successfully!'); }
renderAttTable('CSE301');

// ── MARKS ENTRY ──
const mcSel = document.getElementById('marksCourseSelector');
courses.forEach((c, i) => {
  mcSel.innerHTML += `<button class="marks-course-btn ${i===0?'active':''}" onclick="selectMarksCourse('${c.code}','${c.name}',this)">${c.code} – ${c.name}</button>`;
});
function renderMarksTable(course) {
  const list = attendanceStudents[course] || [];
  document.getElementById('marksTbody').innerHTML = list.map(s => {
    const k = course+'_'+s.roll;
    const m = marksState[k] || { int:0, prac:0, asgn:0 };
    return `
      <tr>
        <td style="font-family:'DM Mono',monospace;font-size:12px;color:var(--text-muted)">${s.roll}</td>
        <td><strong>${s.name}</strong></td>
        <td><input type="number" min="0" max="25" value="${m.int}" onchange="updateMark('${k}','int',this.value)" placeholder="0"></td>
        <td><input type="number" min="0" max="20" value="${m.prac}" onchange="updateMark('${k}','prac',this.value)" placeholder="0"></td>
        <td><input type="number" min="0" max="5" value="${m.asgn}" onchange="updateMark('${k}','asgn',this.value)" placeholder="0"></td>
        <td id="tot_${k}"><strong>${m.int+m.prac+m.asgn}</strong></td>
      </tr>
    `;
  });
}
function updateMark(key, field, val) {
  if (!marksState[key]) marksState[key] = {int:0,prac:0,asgn:0};
  marksState[key][field] = parseInt(val)||0;
  const t = marksState[key];
  document.getElementById('tot_'+key).innerHTML = '<strong>'+(t.int+t.prac+t.asgn)+'</strong>';
}
function selectMarksCourse(code, name, el) {
  document.querySelectorAll('.marks-course-btn').forEach(b => b.classList.remove('active'));
  el.classList.add('active');
  document.getElementById('marksCardTitle').textContent = name+' ('+code+') — Internal Marks';
  renderMarksTable(code);
}
function saveMarks() { showToast('✅ Marks submitted successfully!'); }
renderMarksTable('CSE301');

// ── MY STUDENTS ──
function renderMyStudents(data) {
  document.getElementById('myStudentsTbody').innerHTML = data.map(s => `
    <tr>
      <td><strong>${s.name}</strong></td>
      <td style="font-family:'DM Mono',monospace;font-size:12px;color:var(--text-muted)">${s.roll}</td>
      <td>${s.sem}</td>
      <td><span style="font-family:'DM Mono',monospace;font-size:12px">${s.course}</span></td>
      <td>
        <div style="display:flex;align-items:center;gap:8px">
          <div style="flex:1;height:6px;background:var(--border);border-radius:3px;overflow:hidden;min-width:60px">
            <div style="width:${s.att}%;height:100%;background:${s.att>=75?'var(--green)':'var(--red)'};border-radius:3px"></div>
          </div>
          <span style="font-size:12px;font-weight:600;color:${s.att>=75?'var(--green)':'var(--red)'}">${s.att}%</span>
        </div>
      </td>
      <td>${s.internal}/25</td>
      <td><span class="badge ${s.att>=75?'active':'low'}">${s.att>=75?'Good':'Low Att.'}</span></td>
    </tr>
  `).join('');
}
function filterMyStudents(q) {
  renderMyStudents(myStudents.filter(s =>
    s.name.toLowerCase().includes(q.toLowerCase()) || s.roll.toLowerCase().includes(q.toLowerCase())
  ));
}
renderMyStudents(myStudents);

// ── RESOURCES ──
document.getElementById('resourceGrid').innerHTML = resources.map(r => `
  <div class="resource-card">
    <div style="display:flex;align-items:center;gap:10px">
      <div class="resource-icon" style="background:${r.bg};font-size:18px">${r.icon}</div>
      <div>
        <div style="font-size:10px;font-weight:600;color:var(--text-light);text-transform:uppercase;letter-spacing:0.06em">${r.type}</div>
        <div style="font-size:13px;font-weight:600;margin-top:1px">${r.title}</div>
      </div>
    </div>
    <div class="resource-meta">${r.course} · Uploaded ${r.date}</div>
    <div class="resource-footer">
      <span class="badge done">${r.course}</span>
      <button class="btn-outline" style="padding:4px 12px;font-size:12px">
        <svg width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
        Download
      </button>
    </div>
  </div>
`).join('');

// ── NAVIGATION ──
const titles = { dashboard:'Dashboard', courses:'My Courses', attendance:'Attendance', marks:'Marks Entry', students:'My Students', resources:'Resources', timetable:'Timetable', profile:'My Profile' };
function navigate(page, el) {
  document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));
  document.getElementById('page-'+page).classList.add('active');
  if (el) el.classList.add('active');
  document.getElementById('page-title').textContent = titles[page] || 'Dashboard';
}

// ── TOAST ──
function showToast(msg) {
  const t = document.getElementById('toast');
  t.textContent = msg; t.style.display = 'block';
  setTimeout(() => t.style.display = 'none', 3000);
}
</script>
</body>
</html>
