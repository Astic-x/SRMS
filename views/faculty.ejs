<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SRMS — Faculty Dashboard</title>
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="CSS/faculty.css?v=3" />
    <script>
        // Inject server data into the frontend JS
        window.serverData = <%- serverData %>;
    </script>
</head>
<body>

    <aside class="sidebar">
        <div class="sidebar-logo">
            <div class="logo-title">SRMS</div>
            <div class="logo-sub">Student Record Management System</div>
        </div>
        <nav class="sidebar-nav">
            <div class="nav-section-label">Main</div>
            <div class="nav-item active" onclick="navigate('dashboard',this)">
                <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="3" y="3" width="7" height="7" rx="1" /><rect x="14" y="3" width="7" height="7" rx="1" /><rect x="3" y="14" width="7" height="7" rx="1" /><rect x="14" y="14" width="7" height="7" rx="1" /></svg> Dashboard
            </div>
            <div class="nav-item" onclick="navigate('courses',this)">
                <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M2 3h6a4 4 0 014 4v14a3 3 0 00-3-3H2z" /><path d="M22 3h-6a4 4 0 00-4 4v14a3 3 0 013-3h7z" /></svg> My Courses
            </div>
            <div class="nav-item" onclick="navigate('attendance',this)">
                <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polyline points="9 11 12 14 22 4" /><path d="M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11" /></svg> Attendance
            </div>
            <div class="nav-item" onclick="navigate('marks',this)">
                <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z" /><polyline points="14 2 14 8 20 8" /><line x1="16" y1="13" x2="8" y2="13" /><line x1="16" y1="17" x2="8" y2="17" /></svg> Marks Entry
            </div>
            <div class="nav-item" onclick="navigate('students',this)">
                <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2" /><circle cx="9" cy="7" r="4" /><path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75" /></svg> My Students
            </div>
            <div class="nav-section-label">Tools</div>
            <div class="nav-item" onclick="navigate('resources',this)">
                <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4" /><polyline points="17 8 12 3 7 8" /><line x1="12" y1="3" x2="12" y2="15" /></svg> Resources
            </div>
            <div class="nav-item" onclick="navigate('profile',this)">
                <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="8" r="4" /><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7" /></svg> My Profile
            </div>
            <div class="nav-section-label" style="margin-top: 20px;">Account</div>
            <div class="nav-item" onclick="window.location.href='/logout'" style="color: #e74c3c;">
                <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
                Logout
            </div>
        </nav>

        <div class="sidebar-user">
            <div class="user-avatar"><%= faculty.name.charAt(0) %></div>
            <div>
                <div class="user-name"><%= faculty.name %></div>
                <div class="user-role"><%= faculty.designation %> — <%= faculty.dept_name %></div>
            </div>
        </div>
    </aside>

    <main class="main">
        <header class="topbar">
            <span class="topbar-title" id="page-title">Dashboard</span>
            <div class="topbar-actions">
                <button class="btn-outline" onclick="openUploadModal()">Upload Resource</button>
                <button class="btn-primary" onclick="navigate('attendance', document.querySelector('.nav-item:nth-child(4)'))">Mark Attendance</button>
            </div>
        </header>

        <div class="page active" id="page-dashboard">
            <div class="stats-grid">
                <div class="stat-card">
                    <div class="stat-icon blue"><svg width="20" height="20" fill="none" stroke="#2563EB" stroke-width="2" viewBox="0 0 24 24"><path d="M2 3h6a4 4 0 014 4v14a3 3 0 00-3-3H2z" /><path d="M22 3h-6a4 4 0 00-4 4v14a3 3 0 013-3h7z" /></svg></div>
                    <div>
                        <div class="stat-label">Assigned Courses</div>
                        <div class="stat-value" id="dashCourseCount">0</div>
                        <div class="stat-change neutral">Current Semester</div>
                    </div>
                </div>
                <div class="stat-card">
                    <div class="stat-icon green"><svg width="20" height="20" fill="none" stroke="#16A34A" stroke-width="2" viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2" /><circle cx="9" cy="7" r="4" /></svg></div>
                    <div>
                        <div class="stat-label">Total Students</div>
                        <div class="stat-value" id="dashStudentCount">0</div>
                        <div class="stat-change up">Active Enrollments</div>
                    </div>
                </div>
            </div>
            
            <div class="card" style="margin-top: 24px;">
                <div class="card-header"><span class="card-title">Welcome back, <%= faculty.name %></span></div>
                <p style="color: var(--text-muted); font-size: 14px;">Use the sidebar navigation to manage your courses, enter marks, and track student attendance.</p>
            </div>
        </div>

        <div class="page" id="page-courses">
            <div class="course-grid" id="courseGrid"></div>
        </div>

        <div class="page" id="page-attendance">
            <div class="attendance-toolbar" style="display:flex; gap:12px; align-items:center; flex-wrap:wrap; margin-bottom:16px;">
                <select id="attCourseSelect" class="select-sm" style="font-size:13px;padding:7px 12px" onchange="handleAttChange()"></select>
                <input id="attDate" class="att-date" type="date" style="border:1px solid var(--border); border-radius:6px; padding:6px; font-family:'DM Sans', sans-serif;" onchange="handleAttChange()">
                
                <input id="attSearch" type="text" placeholder="🔍 Search student..." style="border:1px solid var(--border); border-radius:6px; padding:7px 12px; font-size:13px; width:200px;" oninput="renderAttTable()">

                <div class="att-toggle" style="margin-left:auto;">
                    <button class="att-toggle-btn sel" onclick="selectAllAtt('present',this)">All Present</button>
                    <button class="att-toggle-btn" onclick="selectAllAtt('absent',this)">All Absent</button>
                </div>
                <div class="att-summary" style="display:flex; gap:6px;">
                    <span class="att-pill p" id="pCount">P: 0</span>
                    <span class="att-pill a" id="aCount">A: 0</span>
                    <span class="att-pill l" id="lCount">L: 0</span>
                </div>
                <button class="btn-primary" onclick="saveAttendance()">Save</button>
            </div>
            <div class="card">
                <div class="table-wrap">
                    <table>
                        <thead>
                            <tr>
                                <th>Roll No.</th>
                                <th>Student Name</th>
                                <th>Overall %</th> <th>Status</th>
                            </tr>
                        </thead>
                        <tbody id="attTbody"></tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="page" id="page-marks">
            <div class="marks-course-selector" id="marksCourseSelector"></div>
            <div class="card">
                <div class="card-header">
                    <span class="card-title" id="marksCardTitle">Select a Course</span>
                    <button class="btn-primary" onclick="saveMarks()">Submit Marks</button>
                </div>
                <div class="table-wrap">
                    <table>
                        <thead>
                            <tr><th>Roll No.</th><th>Student Name</th><th>Internal (/40)</th><th>External (/60)</th><th>Total (/100)</th></tr>
                        </thead>
                        <tbody id="marksTbody"></tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="page" id="page-students">
            <div style="display:flex;gap:12px;margin-bottom:20px;flex-wrap:wrap">
                <input style="border:1px solid var(--border);border-radius:8px;padding:8px 14px;font-size:13px;width:280px;" placeholder="Search students…" oninput="filterMyStudents(this.value)">
            </div>
            <div class="card">
                <div class="table-wrap">
                    <table>
                        <thead>
                            <tr><th>Student</th><th>Roll No.</th><th>Semester</th><th>Course</th><th>Attendance</th><th>Int. Marks</th></tr>
                        </thead>
                        <tbody id="myStudentsTbody"></tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="page" id="page-resources">
            <div style="display:flex;gap:12px;margin-bottom:20px;align-items:center">
                <button class="btn-primary" style="margin-left:auto" onclick="openUploadModal()">Upload Resource</button>
            </div>
            <div class="resource-grid" id="resourceGrid"></div>
        </div>

        <div class="page" id="page-profile">
            <div class="profile-layout" style="display:grid; grid-template-columns: 1fr 2fr; gap: 24px; align-items: start;">
                
                <div class="profile-card" style="position: sticky; top: 20px;">
                    <div class="profile-avatar"><%= faculty.name.charAt(0) %></div>
                    <div class="profile-name"><%= faculty.name %></div>
                    <div class="profile-dept"><%= faculty.dept_name %></div>
                    <div style="font-size:14px;color:var(--text-muted);margin-top:16px;text-align:left">
                        <div style="margin-bottom:8px"><b>Email:</b> <%= faculty.email %></div>
                        <div style="margin-bottom:8px" id="displayPhone"><b>Phone:</b> <%= faculty.phone %></div>
                        <div><b>Designation:</b> <%= faculty.designation %></div>
                    </div>
                </div>

                <div style="display:flex; flex-direction:column; gap:20px;">
                    
                    <div class="card">
                        <div class="card-title" style="margin-bottom:18px; font-size:16px;">Update Contact Info</div>
                        <form onsubmit="handleUpdatePhone(event)">
                            <div class="form-group">
                                <label>Phone Number</label>
                                <input type="tel" name="phone" value="<%= faculty.phone %>" required style="width:100%; padding:10px; border:1px solid var(--border); border-radius:6px;">
                            </div>
                            <div style="text-align:right"><button type="submit" class="btn-primary">Save Phone</button></div>
                        </form>
                    </div>

                    <div class="card">
                        <div class="card-title" style="margin-bottom:18px; font-size:16px;">Change Login ID (Username)</div>
                        <form onsubmit="handleUpdateUsername(event)">
                            <div class="form-group">
                                <label>New Username</label>
                                <input type="text" name="username" placeholder="Enter new username" required style="width:100%; padding:10px; border:1px solid var(--border); border-radius:6px;">
                            </div>
                            <div style="text-align:right"><button type="submit" class="btn-primary">Update Username</button></div>
                        </form>
                    </div>

                    <div class="card" style="border: 1px solid #fecaca; background: #fffcfc;">
                        <div class="card-title" style="margin-bottom:18px; font-size:16px; color: var(--red);">Security: Change Password</div>
                        <form onsubmit="handleChangePassword(event)">
                            <div class="form-group">
                                <label>Current Password</label>
                                <input type="password" name="currentPassword" required style="width:100%; padding:10px; border:1px solid var(--border); border-radius:6px;">
                            </div>
                            <div class="form-group">
                                <label>New Password (Min 6 chars)</label>
                                <input type="password" name="newPassword" minlength="6" required style="width:100%; padding:10px; border:1px solid var(--border); border-radius:6px;">
                            </div>
                            <div style="text-align:right"><button type="submit" class="btn-primary" style="background: var(--red);">Change Password</button></div>
                        </form>
                    </div>

                </div>
            </div>
        </div>
    </main>

    <div class="modal-overlay" id="uploadModal" onclick="if(event.target===this)this.classList.remove('open')">
        <div class="modal">
            <div class="modal-header">
                <span class="modal-title" id="resModalTitle">Upload Resource</span>
                <button type="button" class="modal-close" onclick="document.getElementById('uploadModal').classList.remove('open')">×</button>
            </div>
            <form id="resourceForm" onsubmit="handleResourceUpload(event)">
                <input type="hidden" name="resource_id" id="resIdInput">
                
                <div class="form-group"><label>Course</label>
                    <select name="course_code" id="resCourseSelect" required></select>
                </div>
                <div class="form-group"><label>Resource Type</label>
                    <select name="type" required>
                        <option value="Lecture Notes">Lecture Notes</option>
                        <option value="Assignment">Assignment</option>
                        <option value="Lab Sheet">Lab Sheet</option>
                        <option value="Syllabus">Syllabus</option>
                        <option value="Previous Year Paper">Previous Year Paper</option>
                    </select>
                </div>
                <div class="form-group"><label>Title</label>
                    <input type="text" name="title" id="resTitleInput" placeholder="e.g. Unit 3 – Trees and Graphs" required>
                </div>
                <div class="form-group"><label>File Link (Google Drive, Dropbox, etc.)</label>
                    <input type="url" name="file_path" id="resPathInput" placeholder="https://..." required>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn-outline" onclick="document.getElementById('uploadModal').classList.remove('open')">Cancel</button>
                    <button type="submit" class="btn-primary" id="resSubmitBtn">Upload</button>
                </div>
            </form>
        </div>
    </div>

    <div id="toast" style="display:none;position:fixed;bottom:28px;right:28px;background:#0F172A;color:#fff;padding:12px 20px;border-radius:10px;font-size:13px;font-weight:600;z-index:999;"></div>

    <script src="JS/faculty.js"></script>
</body>
</html>